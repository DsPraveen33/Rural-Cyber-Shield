{
  "framework": "vite",
  "buildCommand": "pnpm run build",
  "outputDirectory": "artifacts/gramin-rakshak/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://rural-cyber-shield-api.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
